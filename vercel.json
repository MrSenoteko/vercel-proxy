{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Alt-Svc", "value": "clear" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/auth-proxy/(.*)",
      "destination": "https://identitytoolkit.googleapis.com/$1"
    },
    {
      "source": "/token-proxy/(.*)",
      "destination": "https://securetoken.googleapis.com/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "https://firestore.googleapis.com/v1/$1"
    },
    {
      "source": "/google.firestore.v1.Firestore/(.*)",
      "destination": "https://firestore.googleapis.com/google.firestore.v1.Firestore/$1"
    }
  ]
}
